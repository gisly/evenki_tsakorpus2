                <ANNOTATION_VALUE>&#1054;&#1090;&#1082;&#1091;&#1076;&#1072; &#1085;&#1072;&#1096;&#1077;&#1083; &#1090;&#1072;&#1088; &#1073;&#1086;&#772;&#1073;&#1072;&#1081;&#1074;&#1101;, &#1090;&#1072;&#1088; &#1101;&#1088;&#1101;&#1075;&#1101;&#1088; h&#1088;&#1072;&#1085;&#1080;&#1076;&#1103;&#1224;&#1085;&#1072;&#1085;&#1085;&#1080; &#1073;&#1086;.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="aTranslit60" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>&#1048;&#1084;&#1090;&#1099;&#1224;&#1085;&#1101;&#1085;&#1085;&#1080; [=&#1089;&#1084;&#1072;&#1079;&#1099;&#1074;&#1072;&#1077;&#1096;&#1100; &#1078;&#1080;&#1088;&#1086;&#1084;] &#1090;&#1072;&#1088;.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="aTranslit61" TIME_SLOT_REF1="ts125" TIME_SLOT_REF2="ts126">
