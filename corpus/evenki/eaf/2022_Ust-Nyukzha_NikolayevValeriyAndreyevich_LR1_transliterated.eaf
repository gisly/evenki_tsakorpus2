            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="aTranslit63" TIME_SLOT_REF1="ts129" TIME_SLOT_REF2="ts130">
                <ANNOTATION_VALUE>&#1045;&#772;&#1082;&#1091;&#1082;&#1072;&#772;&#1085;&#1076;&#1263;&#1085;-&#1082;&#1072;&#1085;&#1072;&#1085; &#1091;&#1083;&#1083;&#1251;&#1224;&#1085;&#1101;&#1085;&#1085;&#1080; &#1090;&#1099;&#1082;&#1072;&#772;, &#1084;&#275;&#1089;&#1090;&#1086;-&#1082;&#1072;&#1085;&#1072;&#1085;-&#1076;&#1072;&#772;, &#1101;&#1084;&#1101;&#1075;&#1101;&#1085;&#1076;&#1091;&#1083;&#1101;&#772; &#1091;&#1080;&#1084;&#1084;&#1101;&#1085;, &#1090;&#1072;&#1088; &#1101;&#1084;&#1101;&#1075;&#1101;&#1085;&#1076;&#1091;&#1083;&#1101;&#772;&#1074;&#1080;, &#1090;&#1072;&#1088; &#1086;&#1088;&#1086;&#1088; &#1089;&#1086;&#1090; &#1072;&#1103;&#1090; &#1073;&#1080;&#1076;&#1077;&#1076;&#1072;&#772;&#1090;&#1099;&#1085;-&#1082;&#1101;.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="comment">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4497" ANNOTATION_REF="sentFon_aTranslit26">
                <ANNOTATION_VALUE>dagam&#257;ldana: &#1092;&#1086;&#1088;&#1084;&#1072; &#1085;&#1077;&#1103;&#1089;&#1085;&#1072; (&#1087;&#1086;&#1082;&#1072;&#1079;&#1072;&#1090;&#1077;&#1083;&#1100; da &#1074;&#1084;&#1077;&#1089;&#1090;&#1086; &#271;a)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4505" ANNOTATION_REF="sentFon_aTranslit37">
                <ANNOTATION_VALUE>&#271;&#363;tkak&#299;wi: &#1074;&#1086;&#1079;&#1084;&#1086;&#1078;&#1085;&#1086;, &#1092;&#1086;&#1088;&#1084;&#1072;&#1085;&#1090; -tka &#8212; &#1085;&#1072;&#1088;&#1072;&#1097;&#1077;&#1085;&#1080;&#1077;-&#1080;&#1085;&#1090;&#1077;&#1085;&#1089;&#1080;&#1092;&#1080;&#1082;&#1072;&#1090;&#1086;&#1088; &#1076;&#1083;&#1103; &#1087;&#1086;&#1082;&#1072;&#1079;&#1072;&#1090;&#1077;&#1083;&#1103; &#1072;&#1083;&#1083;&#1072;&#1090;&#1080;&#1074;&#1072; (&#1086;&#1078;&#1080;&#1076;&#1072;&#1083;&#1086;&#1089;&#1100; tk&#299;)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="paragraph" TIER_ID="linguist">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4498" TIME_SLOT_REF1="ts123" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>&#1040; &#1077;&#1089;&#1083;&#1080; &#1086;&#1088;&#1086;&#1085;&#1076;&#1091;&#772; &#1073;&#1072;&#1082;&#1072;&#1095;&#1072;&#772;&#1089; [&#1040; &#1077;&#1089;&#1083;&#1080; &#1091; &#1086;&#1083;&#1077;&#1085;&#1103; &#1085;&#1072;&#1096;&#1077;&#1083;? / And if you have found one in a domestic reindeer]</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4506" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>Bobay (a talisman) can be found here.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4507" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>Bobay can only be found once in your life, if you are hunter, for example.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4508" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>Every animal has a bobay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4509" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>The sable has it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4510" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>But it can be found in the stomach, in the upper part.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4511" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>Squirrels have it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4512" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>Wild reindeer have it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4513" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>Domestic reindeer also have it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4514" ANNOTATION_REF="sentFon_aTranslit8">
                <ANNOTATION_VALUE>It is fur covered with a film.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4515" ANNOTATION_REF="sentFon_aTranslit9">
                <ANNOTATION_VALUE>Domestic reindeer have it here.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4516" ANNOTATION_REF="sentFon_aTranslit10">
                <ANNOTATION_VALUE>Domestic reineer have it right here.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4517" ANNOTATION_REF="sentFon_aTranslit11">
                <ANNOTATION_VALUE>You just look, and there is a small lump.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4518" ANNOTATION_REF="sentFon_aTranslit12">
                <ANNOTATION_VALUE>When you kill an old domestic reindeer, you can see it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4519" ANNOTATION_REF="sentFon_aTranslit13">
                <ANNOTATION_VALUE>And it is the bobay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4520" ANNOTATION_REF="sentFon_aTranslit14">
                <ANNOTATION_VALUE>Some elks have it in their stomach, where their stomach is, over it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4521" ANNOTATION_REF="sentFon_aTranslit15">
                <ANNOTATION_VALUE>When I was eighteen, I once [killed] an elk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4522" ANNOTATION_REF="sentFon_aTranslit16">
                <ANNOTATION_VALUE>I went hunting.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4523" ANNOTATION_REF="sentFon_aTranslit17">
                <ANNOTATION_VALUE>I went to hunt a sable.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4524" ANNOTATION_REF="sentFon_aTranslit18">
                <ANNOTATION_VALUE>But my sable dove into a stone run.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4525" ANNOTATION_REF="sentFon_aTranslit19">
                <ANNOTATION_VALUE>I started fuming to make the sable run out.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4526" ANNOTATION_REF="sentFon_aTranslit20">
                <ANNOTATION_VALUE>But my dogs are away, oh, "Where have they gone", thought I.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4527" ANNOTATION_REF="sentFon_aTranslit21">
                <ANNOTATION_VALUE>It was no use [to hunt the sable without dogs].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4528" ANNOTATION_REF="sentFon_aTranslit22">
                <ANNOTATION_VALUE>It was starting to get dark.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4529" ANNOTATION_REF="sentFon_aTranslit23">
                <ANNOTATION_VALUE>I was going away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4530" ANNOTATION_REF="sentFon_aTranslit24">
                <ANNOTATION_VALUE>I went on foot.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4531" ANNOTATION_REF="sentFon_aTranslit25">
                <ANNOTATION_VALUE>My house was close to the place.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4532" ANNOTATION_REF="sentFon_aTranslit26">
                <ANNOTATION_VALUE>When I was approaching my house, the dogs were barking at a female elk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4533" ANNOTATION_REF="sentFon_aTranslit27">
                <ANNOTATION_VALUE>I had no meat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4534" ANNOTATION_REF="sentFon_aTranslit28">
                <ANNOTATION_VALUE>So I fired.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4535" ANNOTATION_REF="sentFon_aTranslit29">
                <ANNOTATION_VALUE>I killed it and skinned it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4536" ANNOTATION_REF="sentFon_aTranslit30">
                <ANNOTATION_VALUE>It was dark, and I wanted to throw away the stomach.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4537" ANNOTATION_REF="sentFon_aTranslit31">
                <ANNOTATION_VALUE>I tore some small lump from the upper part.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4538" ANNOTATION_REF="sentFon_aTranslit32">
                <ANNOTATION_VALUE>A small lump in the upper part.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4539" ANNOTATION_REF="sentFon_aTranslit33">
                <ANNOTATION_VALUE>Why is it hard?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4540" ANNOTATION_REF="sentFon_aTranslit34">
                <ANNOTATION_VALUE>I put it into my pocket, thinking: "I'll show it to my parents".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4541" ANNOTATION_REF="sentFon_aTranslit35">
                <ANNOTATION_VALUE>And...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4542" ANNOTATION_REF="sentFon_aTranslit36">
                <ANNOTATION_VALUE>"It was in the beginning of November, it was warm, [so] it won't freeze", &#8212; I thought [so] I did not chop the meat at the joints.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4543" ANNOTATION_REF="sentFon_aTranslit37">
                <ANNOTATION_VALUE>I just threw away the stomach, the liver and other guts so that it won't get rotten, &#8212; I thought, &#8212; and I went home.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4544" ANNOTATION_REF="sentFon_aTranslit38">
                <ANNOTATION_VALUE>I showed [the lump] to my late mother. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4545" ANNOTATION_REF="sentFon_aTranslit39">
                <ANNOTATION_VALUE>"I've found this in the stomach &#8212;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4546" ANNOTATION_REF="sentFon_aTranslit40">
                <ANNOTATION_VALUE>I said. &#8212;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4547" ANNOTATION_REF="sentFon_aTranslit41">
                <ANNOTATION_VALUE>It is something hard".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4548" ANNOTATION_REF="sentFon_aTranslit42">
                <ANNOTATION_VALUE>There is something like a bone insined, but it is covered with a film.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4549" ANNOTATION_REF="sentFon_aTranslit43">
                <ANNOTATION_VALUE>We started looking at it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4550" ANNOTATION_REF="sentFon_aTranslit44">
                <ANNOTATION_VALUE>It also had holes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4551" ANNOTATION_REF="sentFon_aTranslit45">
                <ANNOTATION_VALUE>"It is the elk talisman" &#8212;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4552" ANNOTATION_REF="sentFon_aTranslit46">
                <ANNOTATION_VALUE>said my late mother.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4553" ANNOTATION_REF="sentFon_aTranslit47">
                <ANNOTATION_VALUE>And she made a special [bag] in this way.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4554" ANNOTATION_REF="sentFon_aTranslit48">
                <ANNOTATION_VALUE>And she told me to carry it in my pouch.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4555" ANNOTATION_REF="sentFon_aTranslit49">
                <ANNOTATION_VALUE>And I usually...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4556" ANNOTATION_REF="sentFon_aTranslit50">
                <ANNOTATION_VALUE>You usually start to feed the bobay [rub it with fat].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4557" ANNOTATION_REF="sentFon_aTranslit51">
                <ANNOTATION_VALUE>If you are going to hunt an elk, you start feeding the bobay [rubbing it with fat].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4558" ANNOTATION_REF="sentFon_aTranslit52">
                <ANNOTATION_VALUE>And the elk won't run away at all.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4559" ANNOTATION_REF="sentFon_aTranslit53">
                <ANNOTATION_VALUE>I hunt it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4560" ANNOTATION_REF="sentFon_aTranslit54">
                <ANNOTATION_VALUE>I've killed a lot of elks with this bobay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4561" ANNOTATION_REF="sentFon_aTranslit55">
                <ANNOTATION_VALUE>Some wild reindeer have it, too.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4562" ANNOTATION_REF="sentFon_aTranslit56">
                <ANNOTATION_VALUE>Some sables.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4563" ANNOTATION_REF="sentFon_aTranslit57">
                <ANNOTATION_VALUE>The late Kolya Chokorok [one-eyed, the nickname of Nikolay Semyonovich Gabyshev] found a bobay in a sable.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4564" ANNOTATION_REF="sentFon_aTranslit58">
                <ANNOTATION_VALUE>And he killed a lot of sables.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4565" ANNOTATION_REF="sentFon_aTranslit59">
                <ANNOTATION_VALUE>If you have found the bobay, you should always keep it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4566" ANNOTATION_REF="sentFon_aTranslit60">
                <ANNOTATION_VALUE>You feed it [rub with fat]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4567" ANNOTATION_REF="sentFon_aTranslit61">
                <ANNOTATION_VALUE>Well, you also keep well the domestic reindeer bobay.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4568" ANNOTATION_REF="sentFon_aTranslit62">
                <ANNOTATION_VALUE>And you attach it to your sadle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4569" ANNOTATION_REF="sentFon_aTranslit63">
                <ANNOTATION_VALUE>You make [a bag], and attach it to your sadle, so that the reindeer will live well.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
