    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="comment">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a326" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>t&#616;k&#257; il&#269;a &#8212; &#1085;&#1077; &#1089;&#1086;&#1074;&#1089;&#1077;&#1084; &#1089;&#1083;&#1099;&#1096;&#1085;&#1086;, &#1085;&#1086; &#1090;&#1072;&#1082;&#1086;&#1081; &#1088;&#1072;&#1079;&#1073;&#1086;&#1088; &#1087;&#1088;&#1077;&#1076;&#1083;&#1086;&#1078;&#1077;&#1085; &#1089;&#1072;&#1084;&#1086;&#1081; &#1075;&#1086;&#1074;&#1086;&#1088;&#1103;&#1097;&#1077;&#1081;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a327" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>They used to kill the bear, too.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a328" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>I once saw a bear when I went to gather berries.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a329" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>Of course, I got scared.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a330" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>Well, we ran away from the place.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a331" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>It stood in that way behind a hazel, and I saw it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a332" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>It rushed after us jumping several times, and we ran away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a333" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>There was a man with us.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>The man started shouting, and the bear got scared.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a335" ANNOTATION_REF="sentFon_aTranslit8">
                <ANNOTATION_VALUE>Because the man was aside.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a336" ANNOTATION_REF="sentFon_aTranslit9">
                <ANNOTATION_VALUE>He shouted.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a337" ANNOTATION_REF="sentFon_aTranslit10">
                <ANNOTATION_VALUE>The bear turned and ran away from us.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
