    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a755" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>Well, Old Girawul and Uncle Babushka told me that, when I was a child.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a756" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>"We had an agreement together.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a757" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>If you have a daughter..."</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a758" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>Oh, at first they would exchange their belts like that.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a759" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>And they would say.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a760" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>"If you have a daughter, my son will definitely marry her.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a761" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>Even if she does not love him, she will marry him", they said.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a762" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>The Evenki had such tradition in the past.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a763" ANNOTATION_REF="sentFon_aTranslit8">
                <ANNOTATION_VALUE>You have to get married without love, whether you want it or not.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a764" ANNOTATION_REF="sentFon_aTranslit9">
                <ANNOTATION_VALUE>And Old Girawul got engaged at the age of eleven.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a765" ANNOTATION_REF="sentFon_aTranslit10">
                <ANNOTATION_VALUE>He was made to engage.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a766" ANNOTATION_REF="sentFon_aTranslit11">
                <ANNOTATION_VALUE>His wife was called Lewu, they say.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a767" ANNOTATION_REF="sentFon_aTranslit12">
                <ANNOTATION_VALUE>Well, I do not know how much cattle her parents had.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a768" ANNOTATION_REF="sentFon_aTranslit13">
                <ANNOTATION_VALUE>Girawul told that himself:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a769" ANNOTATION_REF="sentFon_aTranslit14">
                <ANNOTATION_VALUE>"We would go to clear the cowshed with our dung sledge.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a770" ANNOTATION_REF="sentFon_aTranslit15">
                <ANNOTATION_VALUE>We would gather cowdung with that Lewu".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a771" ANNOTATION_REF="sentFon_aTranslit16">
                <ANNOTATION_VALUE>How old she was, perhaps ten.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a772" ANNOTATION_REF="sentFon_aTranslit17">
                <ANNOTATION_VALUE>"Having done my work with the dung sledge, I would push my bride Lewu right into the dung".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a773" ANNOTATION_REF="sentFon_aTranslit18">
                <ANNOTATION_VALUE>He told that.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a774" ANNOTATION_REF="sentFon_aTranslit19">
                <ANNOTATION_VALUE>So, Girawul was made to engage at the age of eleven, they say.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a775" ANNOTATION_REF="sentFon_aTranslit20">
                <ANNOTATION_VALUE>They must have exchanged their belt buckles.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a776" ANNOTATION_REF="sentFon_aTranslit21">
                <ANNOTATION_VALUE>That Girawul died at the age of ninety nine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
