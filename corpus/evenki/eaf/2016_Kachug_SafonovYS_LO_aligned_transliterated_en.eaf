        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2750" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>We were riding on a sled.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2751" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>And the bear was walking along the summer pasture trail, along the mountain.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2752" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>The dogs started barking at us.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2753" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>Then mama comes running like this.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2754" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>She says:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2755" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>"The dogs have chased the bear up a tree."</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2756" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>And for shooting, father had a "Belka" [=Squirrel], a rifle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2757" ANNOTATION_REF="sentFon_aTranslit8">
                <ANNOTATION_VALUE>Well, we took a carbine and went with Aleksandr Garamzin.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2758" ANNOTATION_REF="sentFon_aTranslit9">
                <ANNOTATION_VALUE>Aleksandr shot him in the forehead.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2759" ANNOTATION_REF="sentFon_aTranslit10">
                <ANNOTATION_VALUE>He fell.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2760" ANNOTATION_REF="sentFon_aTranslit11">
                <ANNOTATION_VALUE>I shot at him there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2761" ANNOTATION_REF="sentFon_aTranslit12">
                <ANNOTATION_VALUE>That was my first bear.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2762" ANNOTATION_REF="sentFon_aTranslit13">
                <ANNOTATION_VALUE>We killed one starving bear.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2763" ANNOTATION_REF="sentFon_aTranslit14">
                <ANNOTATION_VALUE>He...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2764" ANNOTATION_REF="sentFon_aTranslit15">
                <ANNOTATION_VALUE>Have you seen the old village [the old Soviet cultural outpost of Tutura]?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2765" ANNOTATION_REF="sentFon_aTranslit16">
                <ANNOTATION_VALUE>Well, over here, right here, this.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2766" ANNOTATION_REF="sentFon_aTranslit17">
                <ANNOTATION_VALUE>My mother-in-law lived in this, how to say, she lived.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2767" ANNOTATION_REF="sentFon_aTranslit18">
                <ANNOTATION_VALUE>In another house people had gathered, either to hunt or something.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2768" ANNOTATION_REF="sentFon_aTranslit19">
                <ANNOTATION_VALUE>The bear ran out from there,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2769" ANNOTATION_REF="sentFon_aTranslit20">
                <ANNOTATION_VALUE>jumped over the fence.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2770" ANNOTATION_REF="sentFon_aTranslit21">
                <ANNOTATION_VALUE>There was a calf there, and straight towards it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2771" ANNOTATION_REF="sentFon_aTranslit22">
                <ANNOTATION_VALUE>There in another house &#8212; they had all gathered.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2772" ANNOTATION_REF="sentFon_aTranslit23">
                <ANNOTATION_VALUE>It's getting dark already.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2773" ANNOTATION_REF="sentFon_aTranslit24">
                <ANNOTATION_VALUE>Artyom then...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2774" ANNOTATION_REF="sentFon_aTranslit25">
                <ANNOTATION_VALUE>Grandma came out.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2775" ANNOTATION_REF="sentFon_aTranslit26">
                <ANNOTATION_VALUE>She says:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2776" ANNOTATION_REF="sentFon_aTranslit27">
                <ANNOTATION_VALUE>"The bear is running straight towards the calf."</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2777" ANNOTATION_REF="sentFon_aTranslit28">
                <ANNOTATION_VALUE>Artyom saw it,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2778" ANNOTATION_REF="sentFon_aTranslit29">
                <ANNOTATION_VALUE>came running,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2779" ANNOTATION_REF="sentFon_aTranslit30">
                <ANNOTATION_VALUE>grabbed the rifle and right there in the yard started shooting at it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2780" ANNOTATION_REF="sentFon_aTranslit31">
                <ANNOTATION_VALUE>Well, the bear turned around there and back over the fence and ran off.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2781" ANNOTATION_REF="sentFon_aTranslit32">
                <ANNOTATION_VALUE>Then this one came, her son.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2782" ANNOTATION_REF="sentFon_aTranslit33">
                <ANNOTATION_VALUE>He came back from hunting, to his mother, and says:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2783" ANNOTATION_REF="sentFon_aTranslit34">
                <ANNOTATION_VALUE>"My dog started barking at something, at a squirrel.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2784" ANNOTATION_REF="sentFon_aTranslit35">
                <ANNOTATION_VALUE>Then she went quiet.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2785" ANNOTATION_REF="sentFon_aTranslit36">
                <ANNOTATION_VALUE>I saw: something is running past me."</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2786" ANNOTATION_REF="sentFon_aTranslit37">
                <ANNOTATION_VALUE>He hid behind a tree.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2787" ANNOTATION_REF="sentFon_aTranslit38">
                <ANNOTATION_VALUE>They ran past.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2788" ANNOTATION_REF="sentFon_aTranslit39">
                <ANNOTATION_VALUE>The bear is chasing her.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2789" ANNOTATION_REF="sentFon_aTranslit40">
                <ANNOTATION_VALUE>She goes under the fence, the dog,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2790" ANNOTATION_REF="sentFon_aTranslit41">
                <ANNOTATION_VALUE>and the bear goes over the fence.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2791" ANNOTATION_REF="sentFon_aTranslit42">
                <ANNOTATION_VALUE>Well, and so, there they saw the calf.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2792" ANNOTATION_REF="sentFon_aTranslit43">
                <ANNOTATION_VALUE>He came to me,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2793" ANNOTATION_REF="sentFon_aTranslit44">
                <ANNOTATION_VALUE>says:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2794" ANNOTATION_REF="sentFon_aTranslit45">
                <ANNOTATION_VALUE>"Will you go tomorrow?"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2795" ANNOTATION_REF="sentFon_aTranslit46">
                <ANNOTATION_VALUE>"I'll go, why?"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2796" ANNOTATION_REF="sentFon_aTranslit47">
                <ANNOTATION_VALUE>In the morning, very early, we came to Tutura.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2797" ANNOTATION_REF="sentFon_aTranslit48">
                <ANNOTATION_VALUE>People are sitting around.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2798" ANNOTATION_REF="sentFon_aTranslit49">
                <ANNOTATION_VALUE>I had two dogs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2799" ANNOTATION_REF="sentFon_aTranslit50">
                <ANNOTATION_VALUE>They went over there, where the fence is, further beyond it, over there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2800" ANNOTATION_REF="sentFon_aTranslit51">
                <ANNOTATION_VALUE>There I released my dogs on the bear's tracks.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2801" ANNOTATION_REF="sentFon_aTranslit52">
                <ANNOTATION_VALUE>They ran off immediately.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2802" ANNOTATION_REF="sentFon_aTranslit53">
                <ANNOTATION_VALUE>We stood around for a bit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2803" ANNOTATION_REF="sentFon_aTranslit54">
                <ANNOTATION_VALUE>After a little while they started barking.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2804" ANNOTATION_REF="sentFon_aTranslit55">
                <ANNOTATION_VALUE>They started barking,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2805" ANNOTATION_REF="sentFon_aTranslit56">
                <ANNOTATION_VALUE>they're barking not far away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2806" ANNOTATION_REF="sentFon_aTranslit57">
                <ANNOTATION_VALUE>We went there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2807" ANNOTATION_REF="sentFon_aTranslit58">
                <ANNOTATION_VALUE>Who is going to outrun whom?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2808" ANNOTATION_REF="sentFon_aTranslit59">
                <ANNOTATION_VALUE>Well, I was younger, I outran him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2809" ANNOTATION_REF="sentFon_aTranslit60">
                <ANNOTATION_VALUE>Approaching the dogs &#8212;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2810" ANNOTATION_REF="sentFon_aTranslit61">
                <ANNOTATION_VALUE>they're barking at him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2811" ANNOTATION_REF="sentFon_aTranslit62">
                <ANNOTATION_VALUE>He's holding them off with one paw, and slapping with the other, so they don't bite.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2812" ANNOTATION_REF="sentFon_aTranslit63">
                <ANNOTATION_VALUE>Then another one came,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2813" ANNOTATION_REF="sentFon_aTranslit64">
                <ANNOTATION_VALUE>came running.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2814" ANNOTATION_REF="sentFon_aTranslit65">
                <ANNOTATION_VALUE>started shooting.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2815" ANNOTATION_REF="sentFon_aTranslit66">
                <ANNOTATION_VALUE>He shot twice,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2816" ANNOTATION_REF="sentFon_aTranslit67">
                <ANNOTATION_VALUE>I shot three times.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2817" ANNOTATION_REF="sentFon_aTranslit68">
                <ANNOTATION_VALUE>We were running there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2818" ANNOTATION_REF="sentFon_aTranslit69">
                <ANNOTATION_VALUE>A boy, probably Russian, shot from right behind me and missed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2819" ANNOTATION_REF="sentFon_aTranslit70">
                <ANNOTATION_VALUE>The bear broke free and started chasing the dogs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2820" ANNOTATION_REF="sentFon_aTranslit71">
                <ANNOTATION_VALUE>I shot at the running one three times.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2821" ANNOTATION_REF="sentFon_aTranslit72">
                <ANNOTATION_VALUE>He fell then.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2822" ANNOTATION_REF="sentFon_aTranslit73">
                <ANNOTATION_VALUE>There we had to haul him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2823" ANNOTATION_REF="sentFon_aTranslit74">
                <ANNOTATION_VALUE>To skin him, but we, I say, let's drag him whole from there on ropes, drag him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2824" ANNOTATION_REF="sentFon_aTranslit75">
                <ANNOTATION_VALUE>We're dragging.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2825" ANNOTATION_REF="sentFon_aTranslit76">
                <ANNOTATION_VALUE>[unintelligible]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2826" ANNOTATION_REF="sentFon_aTranslit77">
                <ANNOTATION_VALUE>Nothing but bones.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2827" ANNOTATION_REF="sentFon_aTranslit78">
                <ANNOTATION_VALUE>But a good one.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2828" ANNOTATION_REF="sentFon_aTranslit79">
                <ANNOTATION_VALUE>So that these village folk wouldn't be afraid.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2829" ANNOTATION_REF="sentFon_aTranslit80">
                <ANNOTATION_VALUE>It was a famine year.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="fr" LINGUISTIC_TYPE_REF="word" PARENT_REF="sentFon" TIER_ID="fonWord">
