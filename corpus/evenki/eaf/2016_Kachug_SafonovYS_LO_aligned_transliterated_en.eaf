            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a83" ANNOTATION_REF="sentFon_aTranslit1" PREVIOUS_ANNOTATION="a82">
                <ANNOTATION_VALUE>&#331;&#601;n&#601;&#271;&#601;&#269;&#333;wun</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2397" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>a</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2398" ANNOTATION_REF="sentFon_aTranslit2" PREVIOUS_ANNOTATION="a2397">
                <ANNOTATION_VALUE>amaj</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2399" ANNOTATION_REF="sentFon_aTranslit2" PREVIOUS_ANNOTATION="a2398">
                <ANNOTATION_VALUE>ama=</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2400" ANNOTATION_REF="sentFon_aTranslit2" PREVIOUS_ANNOTATION="a2399">
                <ANNOTATION_VALUE>l&#601;t&#324;iktul&#299;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2401" ANNOTATION_REF="sentFon_aTranslit2" PREVIOUS_ANNOTATION="a2400">
                <ANNOTATION_VALUE>ur&#601;l&#299;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2402" ANNOTATION_REF="sentFon_aTranslit2" PREVIOUS_ANNOTATION="a2401">
                <ANNOTATION_VALUE>&#331;&#601;n&#601;&#271;&#601;&#269;&#333;n</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
