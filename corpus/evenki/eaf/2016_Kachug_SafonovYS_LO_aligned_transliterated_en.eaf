                <ANNOTATION_VALUE>bu</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a82" ANNOTATION_REF="sentFon_aTranslit1" PREVIOUS_ANNOTATION="a81">
