            <ALIGNABLE_ANNOTATION ANNOTATION_ID="aTranslit58" TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>&#1075;&#1091;&#1085;&#1080;&#1074;&#1082;&#1251;&#1083;.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="aTranslit59" TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>&#171;&#1041;&#1080; &#1082;&#1101;&#1083;&#1101; &#1090;&#1072;&#1088; &#1089;&#1086;&#772;&#1082;&#1072;&#772;&#1090;&#1082;&#1072;&#772;&#1082;&#1091;&#1085;&#1224;&#1085;&#1101;&#1084;: &#171;&#1054;&#1083; &#1073;&#1101;&#1102;&#1085;&#1084;&#1101; &#1074;&#1072;&#772;&#1084;&#187;, &#8212; &#1075;&#1091;&#1085;&#1085;&#1101;.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="aTranslit60" TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts122">
                <ANNOTATION_VALUE>&#274;-&#275;.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="comment">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1983" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>b&#601;jur&#601;p: &#1079;&#1076;&#1077;&#1089;&#1100; &#1080; &#1076;&#1072;&#1083;&#1077;&#1077; &#1084;&#1086;&#1075;&#1091;&#1090; &#1073;&#1099;&#1090;&#1100; &#1091;&#1087;&#1086;&#1090;&#1088;&#1077;&#1073;&#1083;&#1077;&#1085;&#1099; &#1092;&#1086;&#1088;&#1084;&#1099; &#1089; &#1080;&#1085;&#1082;&#1083;&#1102;&#1079;&#1080;&#1074;&#1085;&#1099;&#1084; &#1087;&#1086;&#1082;&#1072;&#1079;&#1072;&#1090;&#1077;&#1083;&#1077;&#1084; 1pl &#1074;&#1084;&#1077;&#1089;&#1090;&#1086; &#1086;&#1078;&#1080;&#1076;&#1072;&#1077;&#1084;&#1086;&#1075;&#1086; &#1101;&#1082;&#1089;&#1082;&#1083;&#1102;&#1079;&#1080;&#1074;&#1085;&#1086;&#1075;&#1086;.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1980" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>&#1057; &#1050;&#1072;&#1087;&#1080;&#1090;&#1086;&#1083;&#1080;&#1085;&#1086;&#1081; &#1045;&#1075;&#1086;&#1088;&#1086;&#1074;&#1085;&#1086;&#1081; &#1058;&#1088;&#1099;&#1085;&#1082;&#1080;&#1085;&#1086;&#1081; &#1091;&#1095;&#1072;&#1089;&#1090;&#1085;&#1080;&#1082;&#1080; &#1101;&#1082;&#1089;&#1087;&#1077;&#1076;&#1080;&#1094;&#1080;&#1080; &#1074;&#1089;&#1090;&#1088;&#1077;&#1095;&#1072;&#1083;&#1080;&#1089;&#1100; &#1074; &#1054;&#1083;&#1105;&#1082;&#1084;&#1080;&#1085;&#1089;&#1082;&#1077;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1982" ANNOTATION_REF="sentFon_aTranslit54">
                <ANNOTATION_VALUE>&#1059;&#1087;&#1086;&#1090;&#1088;&#1077;&#1073;&#1083;&#1077;&#1085;&#1080;&#1077; "&#1082;&#1080;&#1084;" &#1074; &#1088;&#1086;&#1083;&#1080; &#1087;&#1083;&#1077;&#1081;&#1089;&#1093;&#1086;&#1083;&#1076;&#1077;&#1088;&#1072; &#1093;&#1072;&#1088;&#1072;&#1082;&#1090;&#1077;&#1088;&#1085;&#1086; &#1076;&#1083;&#1103; &#1103;&#1082;&#1091;&#1090;&#1089;&#1082;&#1086;&#1075;&#1086; &#1103;&#1079;&#1099;&#1082;&#1072;. &#1060;&#1086;&#1088;&#1084;&#1072; &#601;&#269;&#601;wr&#601; &#1085;&#1077;&#1103;&#1089;&#1085;&#1072;. &#1040;&#1088;&#1089;&#1077;&#1085;&#1090;&#1080;&#1081; &#1055;&#1088;&#1086;&#1082;&#1086;&#1087;&#1100;&#1077;&#1074;&#1080;&#1095; &#1053;&#1080;&#1082;&#1086;&#1083;&#1072;&#1077;&#1074; (1959&#8212;2021) &#1073;&#1099;&#1083; &#1075;&#1083;&#1072;&#1074;&#1086;&#1081; &#1086;&#1073;&#1097;&#1080;&#1085;&#1099; &#171;&#1058;&#1103;&#1085;&#1103;&#187;, &#1076;&#1077;&#1087;&#1091;&#1090;&#1072;&#1090;&#1086;&#1084; &#1048;&#1083; &#1058;&#1091;&#1084;&#1101;&#1085;. &#1054; &#1085;&#1077;&#1084;, &#1077;&#1075;&#1086; &#1088;&#1072;&#1073;&#1086;&#1090;&#1077; &#1080; &#1082;&#1086;&#1085;&#1092;&#1083;&#1080;&#1082;&#1090;&#1077; &#1089; &#171;&#1053;&#1077;&#1088;&#1102;&#1085;&#1075;&#1088;&#1080;-&#1052;&#1077;&#1090;&#1072;&#1083;&#1083;&#1080;&#1082;&#187;: https://yakutiakmns.org/archives/17149 </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1984" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>I was once hunting with my elder brother.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1985" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>There was Kapa, my younger sister, she was little.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1986" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>You have met her, haven't you?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1987" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>So she, my elder brother and me, we were hunting.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1988" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>We were following our elder brother.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1989" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>Having come, I went there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1990" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>I hunted.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1991" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>"Roza, shoot some ducks for dinner", &#8212;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1992" ANNOTATION_REF="sentFon_aTranslit8">
                <ANNOTATION_VALUE>he said.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1993" ANNOTATION_REF="sentFon_aTranslit9">
                <ANNOTATION_VALUE>So I am going to shoot ducks.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1994" ANNOTATION_REF="sentFon_aTranslit10">
                <ANNOTATION_VALUE>Suddenly, there are wild reindeer going to the river.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1995" ANNOTATION_REF="sentFon_aTranslit11">
                <ANNOTATION_VALUE>So I started to cross the river.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1996" ANNOTATION_REF="sentFon_aTranslit12">
                <ANNOTATION_VALUE>I almost dropped my Tula Arms Plant rifle into the water, grasping it quickly.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1997" ANNOTATION_REF="sentFon_aTranslit13">
                <ANNOTATION_VALUE>Well, when I was coming to the bushes, hiding, a wild reindeer started to walk there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1998" ANNOTATION_REF="sentFon_aTranslit14">
                <ANNOTATION_VALUE>I fired.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1999" ANNOTATION_REF="sentFon_aTranslit15">
                <ANNOTATION_VALUE>"Bang, bang" &#8212; </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2000" ANNOTATION_REF="sentFon_aTranslit16">
                <ANNOTATION_VALUE>I fired again.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2001" ANNOTATION_REF="sentFon_aTranslit17">
                <ANNOTATION_VALUE>It made, "Bang!"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2002" ANNOTATION_REF="sentFon_aTranslit18">
                <ANNOTATION_VALUE>It fell down there, its legs were like that.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2003" ANNOTATION_REF="sentFon_aTranslit19">
                <ANNOTATION_VALUE>Then there was suddenly a second one, a little one.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2004" ANNOTATION_REF="sentFon_aTranslit20">
                <ANNOTATION_VALUE>It had come to the river's water.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2005" ANNOTATION_REF="sentFon_aTranslit21">
                <ANNOTATION_VALUE>I shot it, too.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2006" ANNOTATION_REF="sentFon_aTranslit22">
                <ANNOTATION_VALUE>It [fell down] right into the water.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2007" ANNOTATION_REF="sentFon_aTranslit23">
                <ANNOTATION_VALUE>It came up,</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2008" ANNOTATION_REF="sentFon_aTranslit24">
                <ANNOTATION_VALUE>ran away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2009" ANNOTATION_REF="sentFon_aTranslit25">
                <ANNOTATION_VALUE>Then a black tame reindeer saw this.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2010" ANNOTATION_REF="sentFon_aTranslit26">
                <ANNOTATION_VALUE>"Mae, mae, mae, mae, mae", &#8212;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2011" ANNOTATION_REF="sentFon_aTranslit27">
                <ANNOTATION_VALUE>i am saying.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2012" ANNOTATION_REF="sentFon_aTranslit28">
                <ANNOTATION_VALUE>Why would it come?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2013" ANNOTATION_REF="sentFon_aTranslit29">
                <ANNOTATION_VALUE>Oh, it kept going.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2014" ANNOTATION_REF="sentFon_aTranslit30">
                <ANNOTATION_VALUE>It went away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2015" ANNOTATION_REF="sentFon_aTranslit31">
                <ANNOTATION_VALUE>So, I am trying to skin the one [I have shot].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2016" ANNOTATION_REF="sentFon_aTranslit32">
                <ANNOTATION_VALUE>I had a small knife of such size.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2017" ANNOTATION_REF="sentFon_aTranslit33">
                <ANNOTATION_VALUE>So I am whetting it with whatchamacallit, a stone.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2018" ANNOTATION_REF="sentFon_aTranslit34">
                <ANNOTATION_VALUE>And I am skinning it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2019" ANNOTATION_REF="sentFon_aTranslit35">
                <ANNOTATION_VALUE>So, I am skinning, skinning, skinning, skinning with much effort, I finished it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2020" ANNOTATION_REF="sentFon_aTranslit36">
                <ANNOTATION_VALUE>What a large one!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2021" ANNOTATION_REF="sentFon_aTranslit37">
                <ANNOTATION_VALUE>So, having finished like that and having cut off the meat, having put it down...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2022" ANNOTATION_REF="sentFon_aTranslit38">
                <ANNOTATION_VALUE>My younger sister Kapa was busy about her smoking fires...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2023" ANNOTATION_REF="sentFon_aTranslit39">
                <ANNOTATION_VALUE>We were nomadizing with our reindeer at the time.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2024" ANNOTATION_REF="sentFon_aTranslit40">
                <ANNOTATION_VALUE>We had five tame reindeer or so.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2025" ANNOTATION_REF="sentFon_aTranslit41">
                <ANNOTATION_VALUE>[Kapa] is looking after them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2026" ANNOTATION_REF="sentFon_aTranslit42">
                <ANNOTATION_VALUE>"Kapa!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2027" ANNOTATION_REF="sentFon_aTranslit43">
                <ANNOTATION_VALUE>I have killed a wild reindeer!"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2028" ANNOTATION_REF="sentFon_aTranslit44">
                <ANNOTATION_VALUE>I shout.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2029" ANNOTATION_REF="sentFon_aTranslit45">
                <ANNOTATION_VALUE>So I came, having brought about my younger sister.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2030" ANNOTATION_REF="sentFon_aTranslit46">
                <ANNOTATION_VALUE>So we delivered the meat.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2031" ANNOTATION_REF="sentFon_aTranslit47">
                <ANNOTATION_VALUE>We put it on the reindeer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2032" ANNOTATION_REF="sentFon_aTranslit48">
                <ANNOTATION_VALUE>So, we are crossing the river.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2033" ANNOTATION_REF="sentFon_aTranslit49">
                <ANNOTATION_VALUE>Our elder brother suddenly came there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2034" ANNOTATION_REF="sentFon_aTranslit50">
                <ANNOTATION_VALUE>He came and saw the killed wild reindeer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2035" ANNOTATION_REF="sentFon_aTranslit51">
                <ANNOTATION_VALUE>He looked at it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2036" ANNOTATION_REF="sentFon_aTranslit52">
                <ANNOTATION_VALUE>This elder brother died.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2037" ANNOTATION_REF="sentFon_aTranslit53">
                <ANNOTATION_VALUE>He is gone.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2038" ANNOTATION_REF="sentFon_aTranslit54">
                <ANNOTATION_VALUE>Do you remember Arsentiy Prokopyevich Nikolaev?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2039" ANNOTATION_REF="sentFon_aTranslit55">
                <ANNOTATION_VALUE>It was his father.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2040" ANNOTATION_REF="sentFon_aTranslit56">
                <ANNOTATION_VALUE>He grew up together with him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2041" ANNOTATION_REF="sentFon_aTranslit57">
                <ANNOTATION_VALUE>"Her elder brother has not killed a wild reindeer, whereas Roza was the first to kill",</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2042" ANNOTATION_REF="sentFon_aTranslit58">
                <ANNOTATION_VALUE>everyone was saying.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2043" ANNOTATION_REF="sentFon_aTranslit59">
                <ANNOTATION_VALUE>So I am boasting saying: "I have killed a wild reindeer".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a2044" ANNOTATION_REF="sentFon_aTranslit60">
                <ANNOTATION_VALUE>Yeah.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
