    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a295" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>Old people used to talk about the head.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a296" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>There is a place upstream, at the Yakatyn tundra.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a297" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>A long time ago some person died there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a298" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>A head used to roll there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a299" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>It used to go to the river to drink.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a300" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>One hunter placed his tent there, he was with his reindeer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a301" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>The head rolled right through his tent on its way to the river.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a302" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>He got scared and rushed away on his reindeer at night.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
