                <ANNOTATION_VALUE>&#1053;&#1091; &#1101;&#1090;&#1086; &#1077;&#1089;&#1083;&#1080; &#1082;&#1090;&#1086;-&#1090;&#1086; &#1091;&#1090;&#1086;&#1085;&#1091;&#1083;, &#1076;&#1072;?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a654" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>This is for the master of the water.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a655" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>You will make a raft.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a656" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>You will make a person from dough.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a657" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>We will make its eyes like the human, and an arm for it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a658" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>But there should not be a leg.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a659" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>Its head made from white horse hair, or taken from a white horse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a661" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>If you have no white horse, you will take from [any] horse.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a662" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>You will paint it all with white paint, so that it will be white.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a663" ANNOTATION_REF="sentFon_aTranslit8">
                <ANNOTATION_VALUE>Along its beard, you will also make it very long.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a664" ANNOTATION_REF="sentFon_aTranslit9">
                <ANNOTATION_VALUE>You will daub white paint on it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a665" ANNOTATION_REF="sentFon_aTranslit10">
                <ANNOTATION_VALUE>Then, having let it on the water, you will shamanize after it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a666" ANNOTATION_REF="sentFon_aTranslit11">
                <ANNOTATION_VALUE>You will sprinkle wine ritually after it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a667" ANNOTATION_REF="sentFon_aTranslit12">
                <ANNOTATION_VALUE>That is how I shamanize.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a668" ANNOTATION_REF="sentFon_aTranslit13">
                <ANNOTATION_VALUE>I am explaining how we treated the master of the water.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a670" ANNOTATION_REF="sentFon_a618">
                <ANNOTATION_VALUE>Yes, I have done it [in Russian].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a672" ANNOTATION_REF="sentFon_a624">
                <ANNOTATION_VALUE>Three or four times [in Russian].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a673" ANNOTATION_REF="sentFon_aTranslit14">
                <ANNOTATION_VALUE>Three, four times.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a674" ANNOTATION_REF="sentFon_aTranslit15">
                <ANNOTATION_VALUE>If cattle dies in the lake, you have to treat that master.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a676" ANNOTATION_REF="sentFon_a640">
                <ANNOTATION_VALUE>Yes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a680" ANNOTATION_REF="sentFon_a647">
                <ANNOTATION_VALUE>That.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a681" ANNOTATION_REF="sentFon_aTranslit16">
                <ANNOTATION_VALUE>You are making the water better, you are clearing it. </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a682" ANNOTATION_REF="sentFon_aTranslit17">
                <ANNOTATION_VALUE>If cattle gets drown and is dead, you have to clear the lake.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a683" ANNOTATION_REF="sentFon_aTranslit18">
                <ANNOTATION_VALUE>If you do not clear, cattle will get drowned, they say.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a721" ANNOTATION_REF="sentFon_a690">
                <ANNOTATION_VALUE>Yes, it is for them not to fall into the water again.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="comment">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a660" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>omiran &#8212; &#1092;&#1086;&#1088;&#1084;&#1072; &#1085;&#1077;&#1103;&#1089;&#1085;&#1072;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="linguist1" TIER_ID="linguist1_en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a669" ANNOTATION_REF="a616">
                <ANNOTATION_VALUE>And have you ever done it yourself?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a671" ANNOTATION_REF="a617">
                <ANNOTATION_VALUE>So you have done it, haven't you?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a675" ANNOTATION_REF="a638">
                <ANNOTATION_VALUE>Is it for the equilibrium on the Earth?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a677" ANNOTATION_REF="a645">
                <ANNOTATION_VALUE>Good for everything.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a679" ANNOTATION_REF="a652">
                <ANNOTATION_VALUE>Yes, after that?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="linguist2" TIER_ID="linguist2_en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a678" ANNOTATION_REF="a653">
                <ANNOTATION_VALUE>It is when someone dies.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
