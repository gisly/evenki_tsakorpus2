    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="rustype" PARENT_REF="sentFon" TIER_ID="en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1034" ANNOTATION_REF="sentFon_aTranslit0">
                <ANNOTATION_VALUE>When I heard once, when I was a child, an old man is shamanizing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1035" ANNOTATION_REF="sentFon_aTranslit1">
                <ANNOTATION_VALUE>He would shamanize.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1036" ANNOTATION_REF="sentFon_aTranslit2">
                <ANNOTATION_VALUE>He pronounced a curse on the wolf, shamizing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1037" ANNOTATION_REF="sentFon_aTranslit3">
                <ANNOTATION_VALUE>So it turns out that he is starting to do it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1038" ANNOTATION_REF="sentFon_aTranslit4">
                <ANNOTATION_VALUE>I was listening to his singing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1039" ANNOTATION_REF="sentFon_aTranslit5">
                <ANNOTATION_VALUE>"Go away early in the morning!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1040" ANNOTATION_REF="sentFon_aTranslit6">
                <ANNOTATION_VALUE>Go away along the stream of a river!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1041" ANNOTATION_REF="sentFon_aTranslit7">
                <ANNOTATION_VALUE>Don't catch the reindeer.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1042" ANNOTATION_REF="sentFon_aTranslit8">
                <ANNOTATION_VALUE>Go, go".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1043" ANNOTATION_REF="sentFon_aTranslit9">
                <ANNOTATION_VALUE>So, so, so.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1044" ANNOTATION_REF="sentFon_aTranslit10">
                <ANNOTATION_VALUE>He is doing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1045" ANNOTATION_REF="sentFon_aTranslit11">
                <ANNOTATION_VALUE>When I was little, I was listening when sleeping.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1046" ANNOTATION_REF="sentFon_aTranslit12">
                <ANNOTATION_VALUE>The people repeating after him, doing like this.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1047" ANNOTATION_REF="sentFon_aTranslit13">
                <ANNOTATION_VALUE>In the morning, my younger sister and I got up:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1048" ANNOTATION_REF="sentFon_aTranslit14">
                <ANNOTATION_VALUE>"Let us go and see along the river's water.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1049" ANNOTATION_REF="sentFon_aTranslit15">
                <ANNOTATION_VALUE>It must have gone there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1050" ANNOTATION_REF="sentFon_aTranslit16">
                <ANNOTATION_VALUE>Let us go and see: the road is upstream, it went [there],</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1051" ANNOTATION_REF="sentFon_aTranslit17">
                <ANNOTATION_VALUE>as [the shaman] said.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1052" ANNOTATION_REF="sentFon_aTranslit18">
                <ANNOTATION_VALUE>So, we ran to the river".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1053" ANNOTATION_REF="sentFon_aTranslit19">
                <ANNOTATION_VALUE>Yeah, it was just like that.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1054" ANNOTATION_REF="sentFon_aTranslit20">
                <ANNOTATION_VALUE>Along the lower part of the river bank the wolf leapt out.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1055" ANNOTATION_REF="sentFon_aTranslit21">
                <ANNOTATION_VALUE>Well, what to say?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1056" ANNOTATION_REF="sentFon_aTranslit22">
                <ANNOTATION_VALUE>He really chased it away, shamanizing.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1057" ANNOTATION_REF="sentFon_aTranslit23">
                <ANNOTATION_VALUE>That is why it went away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1058" ANNOTATION_REF="sentFon_aTranslit24">
                <ANNOTATION_VALUE>When it came, it would kill our reindeer, their cubs and so on.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1059" ANNOTATION_REF="sentFon_aTranslit25">
                <ANNOTATION_VALUE>Then, when my Mum was alone &#8212; we lived separately &#8212; so, when she was alone, a bear came.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1060" ANNOTATION_REF="sentFon_aTranslit26">
                <ANNOTATION_VALUE>The dogs are barking and barking.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1061" ANNOTATION_REF="sentFon_aTranslit27">
                <ANNOTATION_VALUE>I am listening: what?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1062" ANNOTATION_REF="sentFon_aTranslit28">
                <ANNOTATION_VALUE>"What are they barking?", </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1063" ANNOTATION_REF="sentFon_aTranslit29">
                <ANNOTATION_VALUE>I say.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1064" ANNOTATION_REF="sentFon_aTranslit30">
                <ANNOTATION_VALUE>Then my Mum got very frightened.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1065" ANNOTATION_REF="sentFon_aTranslit31">
                <ANNOTATION_VALUE>She took her gun, and, sitting like that, she prayed to God:</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1066" ANNOTATION_REF="sentFon_aTranslit32">
                <ANNOTATION_VALUE>"Don't come!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1067" ANNOTATION_REF="sentFon_aTranslit33">
                <ANNOTATION_VALUE>Go away!"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1068" ANNOTATION_REF="sentFon_aTranslit34">
                <ANNOTATION_VALUE>We were alone, our Father was absent.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1069" ANNOTATION_REF="sentFon_aTranslit35">
                <ANNOTATION_VALUE>All the children were with Mum.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1070" ANNOTATION_REF="sentFon_aTranslit36">
                <ANNOTATION_VALUE>There was her elder sister there, an old woman.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1071" ANNOTATION_REF="sentFon_aTranslit37">
                <ANNOTATION_VALUE>So, it still went away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a1072" ANNOTATION_REF="sentFon_aTranslit38">
                <ANNOTATION_VALUE>It is scary.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
