                <ANNOTATION_VALUE>&#1058;&#1072;&#1076;&#1263; &#1101;&#1082;&#1080;&#1085;&#1080;&#1085; &#1090;&#1099;&#1082;&#1072;&#772;, &#1089;&#1072;&#1075;&#1076;&#1099;&#1082;&#1263;&#1085;.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
